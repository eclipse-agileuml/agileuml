  operation readByte() : int
  pre: true post: true; 

  operation readNbytes(n : int) : Sequence(int)
  pre: true post: true;

  operation readAllBytes() : Sequence(int)
  pre: true post: true;

  operation readObject() : OclAny
  pre: true post: true; 

  operation readMap() : Map
  pre: true post: true; 

  operation readLine() : String
  pre: true post: true; 

  operation readLine(prompt : String) : String
  pre: true post: true; */ 

  function string readAll() 
  { return FileIOLib.File.ReadAllFrom(name); } 

  function Collection[string] readAllLines()
  { string text = FileIOLib.File.ReadAllFrom(name);
    Array[string] lines = text.Split('\n'); 
    return lines.ToCollection(); 
  } 

