  post: result = port; 

  query getLocalPort() : int
  pre: true 
  post: result = port; 

  query list() : Sequence(String)
  pre: true post: true; 

  query listFiles() : Sequence(OclFile)
  pre: true post: true; 

  operation print(s : String) : void
  pre: true  post: true; 

  operation println(s : String) : void
  pre: true  post: true; 

  operation printf(f : String, sq : Sequence) : void
  pre: true  post: true; */ 

  function void write(string s)
  { FileIOLib.File.AppendAllTo(name, s); }  

  function Domain.OclFile append(string s)
  { FileIOLib.File.AppendAllTo(name, s);
    return this; 
  } 

  function void writeN(Collection[string] s, int n) 
  { string text = ""; 
    for (int i = 0; i < n; i+1)
    { text = text + s.Get(i) + "\n"; } 
    FileIOLib.File.AppendAllTo(name, text);
  } 

  /* operation writeByte(x : int) : void
  pre: true post: true; 

  operation writeNbytes(s : Sequence(int), n : int) : void
  pre: true post: true; */ 

  function void writeAllLines(Collection[string] sq)
  { string text = ""; 
    for (int i = 0; i < sq.Length; i+1)
    { text = text + sq.Get(i) + "\n"; } 
    FileIOLib.File.WriteAllTo(name, text);
  } 

  /* 
  operation writeObject(s : OclAny) : void
  pre: true post: true; 

  operation writeMap(s : Map) : void
  pre: true post: true; */ 

  operation void writeln(string s)
  { FileIOLib.File.AppendAllTo(name, s + "\n"); } 

  function void flush()
  { } 

