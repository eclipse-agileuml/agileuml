  function bool delete() 
  { try 
    { FileIOLib.File.Delete(name); 
      return true;   
    }  
    catch Exception ex 
    { return false; } 
  } 

  static function bool deleteFile(string nme)
  { try 
    { FileIOLib.File.Delete(nme); 
      return true;   
    }  
    catch Exception ex 
    { return false; } 
  } 

