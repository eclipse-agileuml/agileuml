  attribute name identity : String; 
  attribute port : int; 
  attribute position : long; 
  attribute markedPosition : long; 
  attribute eof : boolean; 
  attribute lastRead : String; 

  static function Domain.OclFile newOclFile(string nme)
  { Domain.OclFile f = Domain.OclFile.Create(); 
    f.name = nme; 
    return f; 
  } 

  /* static operation newOclFile_Remote(nme : String, portNumber: int) : OclFile
  pre: true 
  post: OclFile->exists( f | f.name = nme & f.port = portNumber & result = f ); */  

  static function Domain.OclFile newOclFileRead(Domain.OclFile f)
  { return f; } 

  static function Domain.OclFile newOclFileWrite(Domain.OclFile f)
  { return f; } 

  static function Domain.OclFile newOclFileRW(Domain.OclFile f)
  { return f; }  

