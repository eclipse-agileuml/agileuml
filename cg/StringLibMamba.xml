        <Operation RuleType="Default" EventName="" ApplyToAttribute="" Name="ABC099B" Description="" Syntax="" BaseInfo="" IsStatic="false" IsInherited="false" IsExternal="false">function void ABC099B() 
{
    INP = "3 18 ";
    for (int performTimes = 1; performTimes &lt;= ABLEN; performTimes+1)
    {
      J = CUR;
    while (INP.Substring(J - 1, 1) != " ")    {
      J = J + 1;
    }
    LEN = J - CUR;
    AB11.Set(I - 1, byte.Parse(INP.Substring(CUR - 1, LEN)));
    CUR = J + 1;
    I = I + 1;
    }
    DIV = (AB11.Get(2 - 1) as int) - (AB11.Get(1 - 1) as int);
    S1 = 0;
    I = 1;
    S1 = S1 + DIV * I + (DIV * (DIV - 1)) / 2;
    I = I + DIV;
    T = S1 - (AB11.Get(2 - 1) as int);
    ANS = T;
    DebugLib.Logger.WriteInfoLine("" + ANS + "");
}</Operation>
