        <Operation RuleType="Default" EventName="" ApplyToAttribute="" Name="swapCase" Description="" Syntax="" BaseInfo="" IsStatic="true" IsInherited="false" IsExternal="false">static function string swapCase(string s) 
{
  int ind = 1;
  string res = "";

  while (ind &lt;= s.Length)
  { string chr = "" + s.CharAt(ind - 1);
    if (chr.Equals(chr.ToUpper()))
    { res = res + chr.ToLower(); }
    else
    { res = res + chr.ToUpper(); }
    ind = ind + 1;
  }

  return res;
}</Operation>
