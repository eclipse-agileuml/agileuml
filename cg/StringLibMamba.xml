        <Operation RuleType="Default" EventName="" ApplyToAttribute="" Name="capitalise" Description="" Syntax="" BaseInfo="" IsStatic="true" IsInherited="false" IsExternal="false">static function string capitalise(string str)
{ 
  if (str.Length &gt; 0)
  { string s1 = str.CharAt(0) + "";
