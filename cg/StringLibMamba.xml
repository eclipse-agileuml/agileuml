        <Operation RuleType="Default" EventName="" ApplyToAttribute="" Name="leftTrimWith" Description="" Syntax="" BaseInfo="" IsStatic="true" IsInherited="false" IsExternal="false">static function string leftTrimWith(string str, string ch) 
{
  if (str == null || str.Length == 0) 
  { return str; }
  
  for (int i = 0; i &lt; str.Length; i+1)  
  { if (ch.Equals("" + str.CharAt(i)))
    { } 
    else 
    { string trm = str.Substring(i); 
      return trm;
    }
  }
  return ""; 
}</Operation>
