        <Operation RuleType="Default" EventName="" ApplyToAttribute="" Name="sumStringsWithSeparator" Description="" Syntax="" BaseInfo="" IsStatic="true" IsInherited="false" IsExternal="false">static function string sumStringsWithSeparator(Collection[string] lst, string sep) 
{
  string res = "";
  for (int i = 0; i &lt; lst.Length; i+1)
  { string xx = lst.Get(i);
    res = res + xx;
    if (i &lt; lst.Length - 1)
    { res = res + sep; }
  }
  return res;
}</Operation>
